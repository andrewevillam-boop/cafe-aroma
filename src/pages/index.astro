---
import Layout from "@/layouts/Layout.astro"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { LayoutGrid, Users } from "lucide-react"
import { mesas } from "@/data/mock"

const variantPorEstado = {
  Disponible: "secondary",
  Activa:     "default",
  Cerrada:    "destructive",
} as const
---

<Layout title="Dashboard">
  <h1 class="text-2xl font-bold mb-1">Dashboard</h1>
  <p class="text-muted-foreground mb-6 text-sm">Visión general del salón en tiempo real</p>

  <Card>
    <CardHeader>
      <CardTitle className="flex items-center gap-2 text-base">
        <LayoutGrid className="h-4 w-4 text-primary shrink-0" />
        Estado de Mesas
      </CardTitle>
    </CardHeader>
    <CardContent className="p-4">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
        {mesas.map(mesa => (
          <Card>
            <CardHeader className="pb-1 pt-4 px-4">
              <CardTitle className="text-base">Mesa {mesa.id}</CardTitle>
            </CardHeader>
            <CardContent className="flex justify-between items-center px-4 pb-4">
              <span class="flex items-center gap-1 text-sm text-muted-foreground">
                <Users className="h-3.5 w-3.5" />
                {mesa.capacidad}
              </span>
              <Badge variant={variantPorEstado[mesa.estado]}>{mesa.estado}</Badge>
            </CardContent>
          </Card>
        ))}
      </div>
    </CardContent>
  </Card>
</Layout>
