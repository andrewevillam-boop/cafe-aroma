---
import Nav from "@/components/Nav.astro"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { mesas } from "@/data/mock"
import "@/styles/global.css"

const variantPorEstado = {
  Disponible: "secondary",
  Activa:     "default",
  Cerrada:    "destructive",
} as const
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Café Aroma — Dashboard</title>
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <Nav />
    <main class="p-6 max-w-4xl mx-auto">
      <h1 class="text-2xl font-bold mb-6">Estado de Mesas</h1>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {mesas.map(mesa => (
          <Card>
            <CardHeader class="pb-2">
              <CardTitle class="text-lg">Mesa {mesa.id}</CardTitle>
            </CardHeader>
            <CardContent class="flex justify-between items-center">
              <span class="text-sm text-muted-foreground">{mesa.capacidad} personas</span>
              <Badge variant={variantPorEstado[mesa.estado]}>{mesa.estado}</Badge>
            </CardContent>
          </Card>
        ))}
      </div>
    </main>
  </body>
</html>
