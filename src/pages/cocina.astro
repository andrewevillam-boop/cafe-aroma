---
import Layout from "@/layouts/Layout.astro"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { ChefHat, Clock } from "lucide-react"
import { pedidos } from "@/data/mock"
import type { EstadoItem } from "@/data/mock"

const variantPorEstado: Record<EstadoItem, "secondary" | "default" | "outline"> = {
  "Pendiente":       "secondary",
  "En Preparación":  "default",
  "Entregado":       "outline",
}
---

<Layout title="Cocina">
  <h1 class="text-2xl font-bold mb-1">Pantalla de Cocina</h1>
  <p class="text-muted-foreground mb-6 text-sm">{pedidos.length} pedidos activos en este momento</p>

  <Card>
    <CardHeader>
      <CardTitle className="flex items-center gap-2 text-base">
        <ChefHat className="h-4 w-4 text-primary shrink-0" />
        Pedidos Activos
      </CardTitle>
    </CardHeader>
    <CardContent className="p-4">
      <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-4">
        {pedidos.map(pedido => (
          <Card>
            <CardHeader className="pb-2 pt-4 px-4">
              <div class="flex justify-between items-center">
                <CardTitle className="text-base">Mesa {pedido.mesa}</CardTitle>
                <span class="flex items-center gap-1 text-xs text-muted-foreground">
                  <Clock className="h-3 w-3" />
                  {pedido.hora}
                </span>
              </div>
              <p class="text-xs text-muted-foreground">Pedido #{pedido.id}</p>
            </CardHeader>
            <CardContent className="flex flex-col gap-2 px-4 pb-4">
              {pedido.items.map(item => (
                <div class="flex justify-between items-center gap-2">
                  <span class="text-sm truncate">
                    {item.nombre}
                    <span class="text-muted-foreground ml-1">x{item.cantidad}</span>
                  </span>
                  <Badge variant={variantPorEstado[item.estado]} className="shrink-0 text-xs">
                    {item.estado}
                  </Badge>
                </div>
              ))}
            </CardContent>
          </Card>
        ))}
      </div>
    </CardContent>
  </Card>
</Layout>
