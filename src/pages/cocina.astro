---
import Layout from "@/layouts/Layout.astro"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { Clock } from "lucide-react"
import { pedidos } from "@/data/mock"
import type { EstadoItem } from "@/data/mock"

const variantPorEstado: Record<EstadoItem, "secondary" | "default" | "outline"> = {
  "Pendiente":       "secondary",
  "En Preparación":  "default",
  "Entregado":       "outline",
}
---

<Layout title="Cocina">
  <h1 class="text-2xl font-bold mb-1">Pantalla de Cocina</h1>
  <p class="text-muted-foreground mb-6 text-sm">{pedidos.length} pedidos activos</p>

  <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-4">
    {pedidos.map(pedido => (
      <Card>
        <CardHeader class="pb-2 pt-4 px-4">
          <div class="flex justify-between items-center">
            <CardTitle class="text-base">Mesa {pedido.mesa}</CardTitle>
            <span class="flex items-center gap-1 text-xs text-muted-foreground">
              <Clock className="h-3 w-3" />
              {pedido.hora}
            </span>
          </div>
          <p class="text-xs text-muted-foreground">Pedido #{pedido.id}</p>
        </CardHeader>
        <CardContent class="flex flex-col gap-2 px-4 pb-4">
          {pedido.items.map(item => (
            <div class="flex justify-between items-center gap-2">
              <span class="text-sm truncate">
                {item.nombre}
                <span class="text-muted-foreground ml-1">x{item.cantidad}</span>
              </span>
              <Badge variant={variantPorEstado[item.estado]} class="shrink-0 text-xs">
                {item.estado}
              </Badge>
            </div>
          ))}
        </CardContent>
      </Card>
    ))}
  </div>
</Layout>
