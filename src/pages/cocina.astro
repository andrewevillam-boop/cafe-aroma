---
import "@/styles/global.css"
import Nav from "@/components/Nav.astro"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { pedidos } from "@/data/mock"
import type { EstadoItem } from "@/data/mock"

const variantPorEstado: Record<EstadoItem, "secondary" | "default" | "outline"> = {
  "Pendiente":       "secondary",
  "En Preparación":  "default",
  "Entregado":       "outline",
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Café Aroma — Cocina</title>
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <Nav />
    <main class="p-6 max-w-4xl mx-auto">
      <h1 class="text-2xl font-bold mb-6">Pantalla de Cocina</h1>
      <div class="grid md:grid-cols-2 gap-4">
        {pedidos.map(pedido => (
          <Card>
            <CardHeader class="pb-2">
              <div class="flex justify-between items-center">
                <CardTitle class="text-base">Mesa {pedido.mesa}</CardTitle>
                <span class="text-xs text-muted-foreground">{pedido.hora}</span>
              </div>
            </CardHeader>
            <CardContent class="flex flex-col gap-2">
              {pedido.items.map(item => (
                <div class="flex justify-between items-center">
                  <span class="text-sm">
                    {item.nombre} <span class="text-muted-foreground">x{item.cantidad}</span>
                  </span>
                  <Badge variant={variantPorEstado[item.estado]}>{item.estado}</Badge>
                </div>
              ))}
            </CardContent>
          </Card>
        ))}
      </div>
    </main>
  </body>
</html>
