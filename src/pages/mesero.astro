---
import "@/styles/global.css"
import Nav from "@/components/Nav.astro"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { menu, pedidoMesero } from "@/data/mock"

const categorias = ["Bebidas", "Comidas"] as const

const subtotal = pedidoMesero.reduce(
  (acc, item) => acc + item.precio * item.cantidad,
  0
)
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Café Aroma — Mesero</title>
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <Nav />
    <main class="p-6 max-w-5xl mx-auto">
      <h1 class="text-2xl font-bold mb-6">Tomar Pedido — Mesa 2</h1>
      <div class="grid md:grid-cols-2 gap-6">

        <!-- Menú -->
        <div>
          <h2 class="text-lg font-semibold mb-4">Menú</h2>
          {categorias.map(cat => (
            <div class="mb-4">
              <p class="text-sm text-muted-foreground mb-2">{cat}</p>
              <div class="flex flex-col gap-2">
                {menu.filter(item => item.categoria === cat).map(item => (
                  <Card>
                    <CardContent class="flex justify-between items-center py-3 px-4">
                      <span class="text-sm font-medium">{item.nombre}</span>
                      <div class="flex items-center gap-3">
                        <span class="text-sm text-muted-foreground">
                          ${item.precio.toFixed(2)}
                        </span>
                        <Button size="sm" variant="outline">+ Agregar</Button>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- Pedido actual -->
        <div>
          <h2 class="text-lg font-semibold mb-4">Pedido Actual</h2>
          <Card>
            <CardHeader>
              <CardTitle class="text-base">Ítems seleccionados</CardTitle>
            </CardHeader>
            <CardContent class="flex flex-col gap-3">
              {pedidoMesero.map(item => (
                <div class="flex justify-between items-center">
                  <div>
                    <p class="text-sm font-medium">{item.nombre}</p>
                    <p class="text-xs text-muted-foreground">x{item.cantidad}</p>
                  </div>
                  <span class="text-sm">${(item.precio * item.cantidad).toFixed(2)}</span>
                </div>
              ))}
              <div class="border-t pt-3 flex justify-between font-semibold">
                <span>Subtotal</span>
                <span>${subtotal.toFixed(2)}</span>
              </div>
              <Button class="w-full mt-2">Confirmar Pedido</Button>
            </CardContent>
          </Card>
        </div>

      </div>
    </main>
  </body>
</html>
