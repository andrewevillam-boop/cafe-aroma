---
import Layout from "@/layouts/Layout.astro"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Button } from "@/components/ui/button"
import { ShoppingCart, UtensilsCrossed } from "lucide-react"
import { menu, pedidoMesero } from "@/data/mock"
import { MenuPaginado } from "@/components/MenuPaginado"

const subtotal = pedidoMesero.reduce(
  (acc, item) => acc + item.precio * item.cantidad,
  0
)
---

<Layout title="Mesero">
  <h1 class="text-2xl font-bold mb-1">Tomar Pedido</h1>
  <p class="text-muted-foreground mb-6 text-sm">Mesa 6 — 4 personas</p>

  <div class="grid lg:grid-cols-2 gap-6">

    <!-- Sección: Menú -->
    <Card>
      <CardHeader>
        <CardTitle className="flex items-center gap-2 text-base">
          <UtensilsCrossed className="h-4 w-4 text-primary shrink-0" />
          Menú
        </CardTitle>
      </CardHeader>
      <CardContent>
        <MenuPaginado client:load menu={menu} />
      </CardContent>
    </Card>

    <!-- Sección: Pedido actual -->
    <Card>
      <CardHeader>
        <CardTitle className="flex items-center gap-2 text-base">
          <ShoppingCart className="h-4 w-4 text-primary shrink-0" />
          Pedido Actual
          <span class="ml-auto text-sm font-normal text-muted-foreground">
            {pedidoMesero.length} ítems
          </span>
        </CardTitle>
      </CardHeader>
      <CardContent className="flex flex-col gap-3">
        {pedidoMesero.map(item => (
          <div class="flex justify-between items-start">
            <div>
              <p class="text-sm font-medium">{item.nombre}</p>
              <p class="text-xs text-muted-foreground">
                x{item.cantidad} × ${item.precio.toFixed(2)}
              </p>
            </div>
            <span class="text-sm font-medium shrink-0">
              ${(item.precio * item.cantidad).toFixed(2)}
            </span>
          </div>
        ))}

        <div class="border-t pt-3 mt-1 flex justify-between font-semibold text-sm">
          <span>Subtotal</span>
          <span>${subtotal.toFixed(2)}</span>
        </div>

        <div class="flex justify-end mt-1">
          <Button>Confirmar Pedido</Button>
        </div>
      </CardContent>
    </Card>

  </div>
</Layout>
