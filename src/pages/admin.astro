---
import Layout from "@/layouts/Layout.astro"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Button } from "@/components/ui/button"
import {
  Table, TableBody, TableCell,
  TableHead, TableHeader, TableRow,
} from "@/components/ui/table"
import { FileText } from "lucide-react"
import { pedidos } from "@/data/mock"

const pedido = pedidos[3]
const total = pedido.items.reduce(
  (acc, item) => acc + item.precio * item.cantidad,
  0
)
---

<Layout title="Admin">
  <h1 class="text-2xl font-bold mb-1">Facturación</h1>
  <p class="text-muted-foreground mb-6 text-sm">
    Mesa {pedido.mesa} — Pedido #{pedido.id} — {pedido.hora}
  </p>

  <Card>
    <CardHeader>
      <CardTitle className="flex items-center gap-2 text-base">
        <FileText className="h-4 w-4 text-primary shrink-0" />
        Ítems consumidos
      </CardTitle>
    </CardHeader>
    <CardContent>
      <div class="overflow-x-auto">
        <Table>
          <TableHeader>
            <TableRow>
              <TableHead>Producto</TableHead>
              <TableHead className="text-center">Cant.</TableHead>
              <TableHead className="text-right">Precio</TableHead>
              <TableHead className="text-right">Subtotal</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {pedido.items.map(item => (
              <TableRow>
                <TableCell className="font-medium">{item.nombre}</TableCell>
                <TableCell className="text-center">{item.cantidad}</TableCell>
                <TableCell className="text-right">${item.precio.toFixed(2)}</TableCell>
                <TableCell className="text-right">
                  ${(item.precio * item.cantidad).toFixed(2)}
                </TableCell>
              </TableRow>
            ))}
            <TableRow>
              <TableCell colSpan={3} className="text-right font-bold">Total</TableCell>
              <TableCell className="text-right font-bold text-primary">
                ${total.toFixed(2)}
              </TableCell>
            </TableRow>
          </TableBody>
        </Table>
      </div>

      <div class="flex justify-end mt-6">
        <Button className="flex items-center gap-2">
          <FileText className="h-4 w-4" />
          Generar Factura
        </Button>
      </div>
    </CardContent>
  </Card>
</Layout>
