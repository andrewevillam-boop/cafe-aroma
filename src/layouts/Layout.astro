---
import "@/styles/global.css"
import "@/styles/app.css"
import { ClientRouter, fade } from "astro:transitions"
import { LightRays } from "@/components/ui/light-rays"
import { AppSidebar } from "@/components/AppSidebar"

interface Props {
  title: string
}
const { title } = Astro.props
const rutaActual = Astro.url.pathname
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Café Aroma</title>
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground">

    <script is:inline>
      function aplicarTema() {
        const temaGuardado = localStorage.getItem("theme")
        const prefiereDark = window.matchMedia("(prefers-color-scheme: dark)").matches
        if (temaGuardado === "dark" || (!temaGuardado && prefiereDark)) {
          document.documentElement.classList.add("dark")
        } else {
          document.documentElement.classList.remove("dark")
        }
      }
      // Corre en el load inicial y después de cada navegación con ClientRouter
      aplicarTema()
      document.addEventListener("astro:after-swap", aplicarTema)
    </script>

    <!-- Fondo animado detrás de todo -->
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <LightRays client:load opacity={0.18} />
    </div>

    <!-- Sidebar persistido entre navegaciones para evitar re-renders -->
    <AppSidebar client:load currentPath={rutaActual} transition:persist />

    <!-- Contenido principal con transición fade al navegar -->
    <main transition:animate={fade({ duration: "0.2s" })} class="md:ml-64 p-6 pt-14 md:pt-6 pb-6 min-h-screen">
      <slot />
    </main>

  </body>
</html>
